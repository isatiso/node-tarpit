{
    "name": "@tarpit/type-tools",
    "version": "2.1.1",
    "description": "Some types that helped.",
    "author": "Cao Jiahang <sieglive@gmail.com>",
    "homepage": "https://github.com/isatiso/node-tarpit#readme",
    "license": "MIT",
    "main": "lib/index.mjs",
    "types": "lib/index.d.mts",
    "files": [
        "lib"
    ],
    "engines": {
        "node": ">=20"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.mts",
            "import": "./lib/index.mjs",
            "default": "./lib/index.mjs"
        },
        "./package": "./package.json",
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/isatiso/node-tarpit.git"
    },
    "bugs": {
        "url": "https://github.com/isatiso/node-tarpit/issues"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --out-dir lib"
    },
    "devDependencies": {},
    "sideEffects": false
}
